<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow the webview to reach the local engine over http://localhost -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsLocalNetworking</key>
    <true/>
  </dict>
  <!-- Required so the webview can request the microphone for recording -->
  <key>NSMicrophoneUsageDescription</key>
  <string>ItsMyPA records the meetings you choose to record. Audio is transcribed entirely on your device and never leaves it.</string>
</dict>
</plist>
