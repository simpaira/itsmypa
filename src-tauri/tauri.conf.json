{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ItsMyPA",
  "version": "0.1.2",
  "identifier": "com.itsmypa.desktop",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ItsMyPA",
        "width": 1200,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "pybundle/itsmypa-server": "server"
    },
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
